// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hotel {
  id                 String          @id @default(uuid())
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  nome_hotel         String          @db.VarChar(100)
  razao_social       String          @db.VarChar(100)
  nome_fantasia      String          @db.VarChar(100)
  cnpj               String          @unique @db.VarChar(14)
  email_comercial    String          @unique @db.VarChar(255)
  telefone_comercial String          @db.VarChar(11)
  website            String?
  status             String          @default("S") @db.Char(1)

  enderecos          HotelEndereco[]
  users              User[]
  grupos             Grupo[]
  rotas_hoteis       RotaHotel[]

  @@map("hoteis")
}

model HotelEndereco {
  id          String   @id @default(uuid())
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  hotel_id    String
  hotel       Hotel    @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
  rua         String   @db.VarChar(100)
  numero      String   @db.VarChar(10)
  bairro      String   @db.VarChar(50)
  complemento String?
  cep         String   @db.VarChar(8)
  cidade      String   @db.VarChar(50)
  estado      String   @db.VarChar(2)

  @@index([hotel_id])
  @@map("hoteis_enderecos")
}

model User {
  id            String   @id @default(uuid())
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  hotel_id      String
  hotel         Hotel    @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
  nome_completo String   @db.VarChar(255)
  email         String   @unique @db.VarChar(255)
  senha         String   @db.Text
  nascimento    DateTime @db.Date
  genero        String   @db.VarChar(20)
  celular       String   @unique @db.VarChar(20)
  cpf           String   @unique @db.VarChar(14)
  rg            String?  @unique
  grupos_ids    String?  @db.Text

  @@index([hotel_id])
  @@map("users")
}

model Grupo {
  id         String      @id @default(uuid())
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt
  hotel_id   String
  hotel      Hotel       @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
  grupo      String      @db.VarChar(100)
  descricao  String?     @db.Text
  status     String      @default("S") @db.Char(1)
  rotas      GrupoRota[]

  @@unique([hotel_id, grupo])
  @@index([hotel_id])
  @@index([grupo])
  @@map("grupos")
}

model Rota {
  id         String      @id @default(uuid())
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt
  modulo     String      @db.VarChar(100)
  recurso    String      @db.VarChar(100)
  rota       String      @db.VarChar(255)
  icone      String?     @db.VarChar(50)
  ordem      Int         @default(0)
  ativo      Boolean     @default(true)
  hoteis     RotaHotel[]
  grupos     GrupoRota[]

  @@map("rotas")
}

model RotaHotel {
  id         String   @id @default(uuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  hotel_id   String
  hotel      Hotel    @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
  rota_id    String
  rota       Rota     @relation(fields: [rota_id], references: [id], onDelete: Cascade)

  @@unique([hotel_id, rota_id])
  @@index([hotel_id])
  @@map("rotas_hoteis")
}

model GrupoRota {
  id         String   @id @default(uuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  grupo_id   String
  grupo      Grupo    @relation(fields: [grupo_id], references: [id], onDelete: Cascade)
  rota_id    String
  rota       Rota     @relation(fields: [rota_id], references: [id], onDelete: Cascade)

  @@unique([grupo_id, rota_id])
  @@index([grupo_id])
  @@map("grupos_rotas")
}

model Administrator {
  id            String   @id @default(uuid())
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  nome_completo String   @db.VarChar(200)
  email         String   @unique @db.VarChar(150)
  senha         String   @db.Text
  status        String   @default("S") @db.Char(1)

  @@map("administrators")
}
