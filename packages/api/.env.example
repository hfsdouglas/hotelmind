# Servidor
PORT=3000

# Suporte (admin -> web hotel access)
WEB_APP_URL=http://localhost:5173

# Banco de Dados PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hoteis?schema=public"

POSTGRES_DB=hoteis
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Secrets
# Gere novos UUIDs para produção usando: uuidgen
COOKIE_SECRET=your-cookie-secret-uuid-here
JWT_SECRET=your-jwt-secret-uuid-here